<Window x:Class="CourseCenterWPF.Views.DialogWindows.CursantDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="👤 Слушатель" Height="420" Width="450" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#2C3E50" Padding="10" CornerRadius="5" Margin="0,0,0,20">
            <TextBlock Text="Данные слушателя" FontSize="16" FontWeight="Bold" 
                       Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Фамилия:" VerticalAlignment="Center" Margin="0,5" FontWeight="SemiBold"/>
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtNume" Margin="0,5" Padding="8" FontSize="14"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Имя:" VerticalAlignment="Center" Margin="0,5" FontWeight="SemiBold"/>
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtPrenume" Margin="0,5" Padding="8" FontSize="14"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Телефон:" VerticalAlignment="Center" Margin="0,5" FontWeight="SemiBold"/>
        <TextBox Grid.Row="3" Grid.Column="1" x:Name="txtTelefon" Margin="0,5" Padding="8" FontSize="14" 
                 ToolTip="Формат: +373XXXXXXXX"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Email:" VerticalAlignment="Center" Margin="0,5" FontWeight="SemiBold"/>
        <TextBox Grid.Row="4" Grid.Column="1" x:Name="txtEmail" Margin="0,5" Padding="8" FontSize="14"/>

        <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="💾 Сохранить" x:Name="btnSave" Click="BtnSave_Click" 
                    Background="#27AE60" Padding="25,10" Margin="0,0,10,0" IsDefault="True"/>
            <Button Content="❌ Отмена" Click="BtnCancel_Click" 
                    Background="#95A5A6" Padding="25,10"/>
        </StackPanel>
    </Grid>
</Window>