<Window x:Class="CourseCenterWPF.Views.DialogWindows.InscriereDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📝 Регистрация на курс" Height="400" Width="500" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#2C3E50" Padding="10" CornerRadius="5" Margin="0,0,0,20">
            <TextBlock Text="Новая регистрация" FontSize="16" FontWeight="Bold" 
                       Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Слушатель:" VerticalAlignment="Center" Margin="0,5" FontWeight="SemiBold"/>
        <ComboBox Grid.Row="1" Grid.Column="1" x:Name="cmbCursant" Margin="0,5" Padding="8" FontSize="14"
                  DisplayMemberPath="FullName" SelectedValuePath="IdCursant"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Курс:" VerticalAlignment="Center" Margin="0,5" FontWeight="SemiBold"/>
        <ComboBox Grid.Row="2" Grid.Column="1" x:Name="cmbCurs" Margin="0,5" Padding="8" FontSize="14"
                  DisplayMemberPath="Denumire" SelectedValuePath="IdCurs"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Статус оплаты:" VerticalAlignment="Center" Margin="0,5" FontWeight="SemiBold"/>
        <ComboBox Grid.Row="3" Grid.Column="1" x:Name="cmbStatus" Margin="0,5" Padding="8" FontSize="14">
            <ComboBoxItem Content="Не оплачен" Tag="Neplatit"/>
            <ComboBoxItem Content="Оплачен" Tag="Platit"/>
        </ComboBox>

        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="✅ Зарегистрировать" x:Name="btnSave" Click="BtnSave_Click" 
                    Background="#27AE60" Padding="25,10" Margin="0,0,10,0" IsDefault="True"/>
            <Button Content="❌ Отмена" Click="BtnCancel_Click" 
                    Background="#95A5A6" Padding="25,10"/>
        </StackPanel>
    </Grid>
</Window>