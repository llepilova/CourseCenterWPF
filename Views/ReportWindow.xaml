<Window x:Class="CourseCenterWPF.Views.ReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Краткий отчет" Height="620" Width="860"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="txtSummary" FontWeight="SemiBold" Margin="0,0,0,8" TextWrapping="Wrap"/>

        <TextBox Grid.Row="1" x:Name="txtReport" FontFamily="Consolas" FontSize="13"
                 IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto" AcceptsReturn="True"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Экспорт TXT" Click="BtnExport_Click" Padding="16,6" Margin="0,0,8,0"/>
            <Button Content="Закрыть" Click="BtnClose_Click" Padding="16,6"/>
        </StackPanel>
    </Grid>
</Window>
