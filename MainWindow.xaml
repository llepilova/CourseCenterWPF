<Window x:Class="CourseCenterWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CourseCenterWPF.ViewModels"
        Title="Аптека: лекарства, поставщики и поставки"
        Height="820"
        Width="1360"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}">
    <Window.Resources>
        <LinearGradientBrush x:Key="HeroBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#2563EB" Offset="0" />
            <GradientStop Color="#1D4ED8" Offset="1" />
        </LinearGradientBrush>

        <Style TargetType="TabItem">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="{StaticResource AppSurfaceSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                CornerRadius="24"
                Padding="28"
                Background="{StaticResource HeroBackgroundBrush}"
                Margin="0,0,0,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="CourseCenter"
                               Foreground="White"
                               FontSize="32"
                               FontWeight="Bold" />
                    <TextBlock Text="Современный центр учета лекарств, поставщиков и поставок"
                               Margin="0,8,0,0"
                               Foreground="#E0E7FF"
                               FontSize="14"
                               TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <Button Content="Открыть отчет"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Command="{Binding OpenReportCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Лекарства" Style="{StaticResource MetricValueTextStyle}" />
                    <TextBlock Text="Поиск, добавление и редактирование каталога"
                               Margin="0,6,0,0"
                               Style="{StaticResource MetricCaptionTextStyle}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Поставщики" Style="{StaticResource MetricValueTextStyle}" />
                    <TextBlock Text="Контакты, адреса и быстрая фильтрация"
                               Margin="0,6,0,0"
                               Style="{StaticResource MetricCaptionTextStyle}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Поставки" Style="{StaticResource MetricValueTextStyle}" />
                    <TextBlock Text="Фильтры по лекарству, поставщику и датам"
                               Margin="0,6,0,0"
                               Style="{StaticResource MetricCaptionTextStyle}" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}" Padding="18">
            <TabControl Background="Transparent" BorderThickness="0">
                <TabItem Header="Лекарства">
                    <Grid Margin="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Каталог лекарств" Style="{StaticResource SectionTitleTextStyle}" />
                                <TextBlock Text="Найдите, добавьте или обновите карточку препарата."
                                           Margin="0,4,0,0"
                                           Style="{StaticResource SectionSubtitleTextStyle}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="Добавить"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        Margin="0,0,8,0"
                                        Command="{Binding AddMedicamentCommand}" />
                                <Button Content="Изменить"
                                        Margin="0,0,8,0"
                                        Command="{Binding EditMedicamentCommand}" />
                                <Button Content="Удалить"
                                        Command="{Binding DeleteMedicamentCommand}" />
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="1"
                                Style="{StaticResource CardBorderStyle}"
                                Background="{StaticResource AppSurfaceSoftBrush}"
                                Padding="16"
                                Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="340" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding MedicamentSearchText, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}" Padding="0">
                            <DataGrid ItemsSource="{Binding Medicamente}"
                                      SelectedItem="{Binding SelectedMedicament}"
                                      AutoGenerateColumns="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding IdMedicament}" Width="70" />
                                    <DataGridTextColumn Header="Название" Binding="{Binding Denumire}" Width="*" />
                                    <DataGridTextColumn Header="Форма" Binding="{Binding FormaFarmaceutica}" Width="180" />
                                    <DataGridTextColumn Header="Концентрация" Binding="{Binding Concentratie}" Width="150" />
                                    <DataGridTextColumn Header="Цена" Binding="{Binding Pret, StringFormat={}{0:F2}}" Width="110" />
                                    <DataGridTextColumn Header="Остаток" Binding="{Binding StocCurent}" Width="110" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Поставщики">
                    <Grid Margin="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Справочник поставщиков" Style="{StaticResource SectionTitleTextStyle}" />
                                <TextBlock Text="Следите за контактами и редактируйте карточки поставщиков."
                                           Margin="0,4,0,0"
                                           Style="{StaticResource SectionSubtitleTextStyle}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="Добавить"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        Margin="0,0,8,0"
                                        Command="{Binding AddFurnizorCommand}" />
                                <Button Content="Изменить"
                                        Margin="0,0,8,0"
                                        Command="{Binding EditFurnizorCommand}" />
                                <Button Content="Удалить"
                                        Command="{Binding DeleteFurnizorCommand}" />
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="1"
                                Style="{StaticResource CardBorderStyle}"
                                Background="{StaticResource AppSurfaceSoftBrush}"
                                Padding="16"
                                Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="340" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding FurnizorSearchText, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}" Padding="0">
                            <DataGrid ItemsSource="{Binding Furnizori}"
                                      SelectedItem="{Binding SelectedFurnizor}"
                                      AutoGenerateColumns="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding IdFurnizor}" Width="70" />
                                    <DataGridTextColumn Header="Название" Binding="{Binding Denumire}" Width="*" />
                                    <DataGridTextColumn Header="Телефон" Binding="{Binding Telefon}" Width="160" />
                                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="220" />
                                    <DataGridTextColumn Header="Адрес" Binding="{Binding Adresa}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Поставки">
                    <Grid Margin="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Журнал поставок" Style="{StaticResource SectionTitleTextStyle}" />
                                <TextBlock Text="Используйте фильтры по лекарству, поставщику и датам."
                                           Margin="0,4,0,0"
                                           Style="{StaticResource SectionSubtitleTextStyle}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="Сбросить"
                                        Margin="0,0,8,0"
                                        Command="{Binding ResetAprovizionareFiltersCommand}" />
                                <Button Content="Добавить"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        Margin="0,0,8,0"
                                        Command="{Binding AddAprovizionareCommand}" />
                                <Button Content="Изменить"
                                        Margin="0,0,8,0"
                                        Command="{Binding EditAprovizionareCommand}" />
                                <Button Content="Удалить"
                                        Command="{Binding DeleteAprovizionareCommand}" />
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="1"
                                Style="{StaticResource CardBorderStyle}"
                                Background="{StaticResource AppSurfaceSoftBrush}"
                                Padding="16"
                                Margin="0,0,0,16">
                            <WrapPanel ItemHeight="34" ItemWidth="Auto">
                                <StackPanel Margin="0,0,16,12">
                                    <TextBlock Text="Лекарство" Margin="0,0,0,6" />
                                    <ComboBox Width="220"
                                              ItemsSource="{Binding MedicamenteForFilter}"
                                              SelectedItem="{Binding SelectedMedicamentFilter}"
                                              DisplayMemberPath="Denumire" />
                                </StackPanel>
                                <StackPanel Margin="0,0,16,12">
                                    <TextBlock Text="Поставщик" Margin="0,0,0,6" />
                                    <ComboBox Width="220"
                                              ItemsSource="{Binding FurnizoriForFilter}"
                                              SelectedItem="{Binding SelectedFurnizorFilter}"
                                              DisplayMemberPath="Denumire" />
                                </StackPanel>
                                <StackPanel Margin="0,0,16,12">
                                    <TextBlock Text="С" Margin="0,0,0,6" />
                                    <DatePicker Width="140"
                                                SelectedDate="{Binding AprovizionareFromFilter}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,16,12">
                                    <TextBlock Text="По" Margin="0,0,0,6" />
                                    <DatePicker Width="140"
                                                SelectedDate="{Binding AprovizionareToFilter}" />
                                </StackPanel>
                            </WrapPanel>
                        </Border>

                        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}" Padding="0">
                            <DataGrid ItemsSource="{Binding Aprovizionari}"
                                      SelectedItem="{Binding SelectedAprovizionare}"
                                      AutoGenerateColumns="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding IdAprovizionare}" Width="70" />
                                    <DataGridTextColumn Header="Лекарство" Binding="{Binding MedicamentDenumire}" Width="*" />
                                    <DataGridTextColumn Header="Поставщик" Binding="{Binding FurnizorDenumire}" Width="220" />
                                    <DataGridTextColumn Header="Дата" Binding="{Binding DataAprovizionare, StringFormat=dd.MM.yyyy}" Width="120" />
                                    <DataGridTextColumn Header="Количество" Binding="{Binding Cantitate}" Width="110" />
                                    <DataGridTextColumn Header="Цена" Binding="{Binding PretAchizitie, StringFormat={}{0:F2}}" Width="110" />
                                    <DataGridTextColumn Header="Стоимость" Binding="{Binding CostTotal, StringFormat={}{0:F2}}" Width="120" />
                                    <DataGridTextColumn Header="Истекает" Binding="{Binding DataExpirare, StringFormat=dd.MM.yyyy}" Width="120" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Отчет">
                    <Grid Margin="4">
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Быстрый отчет" Style="{StaticResource SectionTitleTextStyle}" />
                                <TextBlock Text="Нажмите «Открыть отчет», чтобы сформировать краткую сводку и экспортировать ее в TXT."
                                           Margin="0,6,0,0"
                                           Style="{StaticResource SectionSubtitleTextStyle}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</Window>
