<Window x:Class="CourseCenterWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CourseCenterWPF.ViewModels"
        Title="Система учета кинотеатра" Height="760" Width="1220"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1F2937" Padding="12" Margin="0,0,0,8" CornerRadius="6">
            <TextBlock Text="Кинотеатр: фильмы, сеансы и билеты" Foreground="White" FontSize="20" FontWeight="Bold"/>
        </Border>

        <TabControl Grid.Row="1">
            <TabItem Header="Фильмы">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Width="260" Text="{Binding FilmSearchText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                        <Button Content="Добавить" Command="{Binding AddFilmCommand}" Margin="0,0,6,0"/>
                        <Button Content="Изменить" Command="{Binding EditFilmCommand}" Margin="0,0,6,0"/>
                        <Button Content="Удалить" Command="{Binding DeleteFilmCommand}"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding Filme}" SelectedItem="{Binding SelectedFilm}" AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding IdFilm}" Width="60"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Titlu}" Width="260"/>
                            <DataGridTextColumn Header="Жанр" Binding="{Binding Gen}" Width="170"/>
                            <DataGridTextColumn Header="Длительность, мин" Binding="{Binding DurataMinute}" Width="130"/>
                            <DataGridTextColumn Header="Возраст+" Binding="{Binding LimitaVarsta}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Сеансы">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Фильм:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox Width="190" ItemsSource="{Binding FilmeForCombo}" SelectedItem="{Binding SelectedFilmFilter}" DisplayMemberPath="Titlu" Margin="0,0,8,0"/>
                        <TextBlock Text="Дата:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <DatePicker Width="140" SelectedDate="{Binding SeansDateFilter}" Margin="0,0,8,0"/>
                        <Button Content="Сбросить фильтры" Command="{Binding ResetSeansFiltersCommand}" Margin="0,0,14,0"/>
                        <Button Content="Добавить" Command="{Binding AddSeansCommand}" Margin="0,0,6,0"/>
                        <Button Content="Изменить" Command="{Binding EditSeansCommand}" Margin="0,0,6,0"/>
                        <Button Content="Удалить" Command="{Binding DeleteSeansCommand}"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding Seanse}" SelectedItem="{Binding SelectedSeans}" AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding IdSeansa}" Width="60"/>
                            <DataGridTextColumn Header="Фильм" Binding="{Binding FilmTitlu}" Width="250"/>
                            <DataGridTextColumn Header="Дата" Binding="{Binding DataSeansa, StringFormat=dd.MM.yyyy}" Width="120"/>
                            <DataGridTextColumn Header="Время" Binding="{Binding OraSeansa}" Width="90"/>
                            <DataGridTextColumn Header="Цена" Binding="{Binding PretBilet, StringFormat={}{0:F2}}" Width="90"/>
                            <DataGridTextColumn Header="Всего мест" Binding="{Binding NumarLocuriTotal}" Width="100"/>
                            <DataGridTextColumn Header="Продано" Binding="{Binding TotalBileteVandute}" Width="90"/>
                            <DataGridTextColumn Header="Свободно" Binding="{Binding LocuriLibere}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Продажи билетов">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <WrapPanel Margin="0,0,0,8">
                        <TextBlock Text="Фильм:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox Width="180" ItemsSource="{Binding FilmeForCombo}" SelectedItem="{Binding SelectedFilmBiletFilter}" DisplayMemberPath="Titlu" Margin="0,0,8,0"/>
                        <TextBlock Text="Сеанс:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox Width="180" ItemsSource="{Binding SeanseForCombo}" SelectedItem="{Binding SelectedSeansBiletFilter}" DisplayMemberPath="FilmTitlu" Margin="0,0,8,0"/>
                        <TextBlock Text="Дата продажи:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <DatePicker Width="140" SelectedDate="{Binding BiletDateFilter}" Margin="0,0,8,0"/>
                        <Button Content="Сбросить" Command="{Binding ResetBiletFiltersCommand}" Margin="0,0,14,0"/>
                        <Button Content="Добавить" Command="{Binding AddBiletCommand}" Margin="0,0,6,0"/>
                        <Button Content="Изменить" Command="{Binding EditBiletCommand}" Margin="0,0,6,0"/>
                        <Button Content="Удалить" Command="{Binding DeleteBiletCommand}"/>
                    </WrapPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding Bilete}" SelectedItem="{Binding SelectedBilet}" AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding IdBilet}" Width="60"/>
                            <DataGridTextColumn Header="Фильм" Binding="{Binding FilmTitlu}" Width="240"/>
                            <DataGridTextColumn Header="Сеанс" Binding="{Binding SeansInfo}" Width="140"/>
                            <DataGridTextColumn Header="Билеты" Binding="{Binding NumarBilete}" Width="90"/>
                            <DataGridTextColumn Header="Скидка, %" Binding="{Binding ReducereProcent}" Width="90"/>
                            <DataGridTextColumn Header="Сумма" Binding="{Binding SumaAchitata, StringFormat={}{0:F2}}" Width="100"/>
                            <DataGridTextColumn Header="Дата продажи" Binding="{Binding DataVanzare, StringFormat=dd.MM.yyyy}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
