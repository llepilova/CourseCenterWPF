<Window x:Class="CourseCenterWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CourseCenterWPF.ViewModels"
        Title="Аптека: лекарства, поставщики и поставки" Height="780" Width="1280"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1F2937" Padding="12" Margin="0,0,0,8" CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Система учета лекарств, поставщиков и поставок" Foreground="White" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Открыть отчет" Command="{Binding OpenReportCommand}" Padding="14,6" Margin="12,0,0,0"/>
            </Grid>
        </Border>

        <TabControl Grid.Row="1">
            <TabItem Header="Лекарства">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <WrapPanel Margin="0,0,0,8">
                        <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Width="280" Text="{Binding MedicamentSearchText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                        <Button Content="Добавить" Command="{Binding AddMedicamentCommand}" Margin="0,0,6,0"/>
                        <Button Content="Изменить" Command="{Binding EditMedicamentCommand}" Margin="0,0,6,0"/>
                        <Button Content="Удалить" Command="{Binding DeleteMedicamentCommand}"/>
                    </WrapPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding Medicamente}" SelectedItem="{Binding SelectedMedicament}" AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding IdMedicament}" Width="60"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Denumire}" Width="220"/>
                            <DataGridTextColumn Header="Форма" Binding="{Binding FormaFarmaceutica}" Width="180"/>
                            <DataGridTextColumn Header="Концентрация" Binding="{Binding Concentratie}" Width="150"/>
                            <DataGridTextColumn Header="Цена" Binding="{Binding Pret, StringFormat={}{0:F2}}" Width="100"/>
                            <DataGridTextColumn Header="Остаток" Binding="{Binding StocCurent}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Поставщики">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <WrapPanel Margin="0,0,0,8">
                        <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Width="280" Text="{Binding FurnizorSearchText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                        <Button Content="Добавить" Command="{Binding AddFurnizorCommand}" Margin="0,0,6,0"/>
                        <Button Content="Изменить" Command="{Binding EditFurnizorCommand}" Margin="0,0,6,0"/>
                        <Button Content="Удалить" Command="{Binding DeleteFurnizorCommand}"/>
                    </WrapPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding Furnizori}" SelectedItem="{Binding SelectedFurnizor}" AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding IdFurnizor}" Width="60"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Denumire}" Width="220"/>
                            <DataGridTextColumn Header="Телефон" Binding="{Binding Telefon}" Width="150"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="220"/>
                            <DataGridTextColumn Header="Адрес" Binding="{Binding Adresa}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Поставки">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <WrapPanel Margin="0,0,0,8">
                        <TextBlock Text="Лекарство:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox Width="180" ItemsSource="{Binding MedicamenteForFilter}" SelectedItem="{Binding SelectedMedicamentFilter}" DisplayMemberPath="Denumire" Margin="0,0,8,0"/>
                        <TextBlock Text="Поставщик:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox Width="180" ItemsSource="{Binding FurnizoriForFilter}" SelectedItem="{Binding SelectedFurnizorFilter}" DisplayMemberPath="Denumire" Margin="0,0,8,0"/>
                        <TextBlock Text="С:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <DatePicker Width="130" SelectedDate="{Binding AprovizionareFromFilter}" Margin="0,0,8,0"/>
                        <TextBlock Text="По:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <DatePicker Width="130" SelectedDate="{Binding AprovizionareToFilter}" Margin="0,0,8,0"/>
                        <Button Content="Сбросить" Command="{Binding ResetAprovizionareFiltersCommand}" Margin="0,0,14,0"/>
                        <Button Content="Добавить" Command="{Binding AddAprovizionareCommand}" Margin="0,0,6,0"/>
                        <Button Content="Изменить" Command="{Binding EditAprovizionareCommand}" Margin="0,0,6,0"/>
                        <Button Content="Удалить" Command="{Binding DeleteAprovizionareCommand}"/>
                    </WrapPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding Aprovizionari}" SelectedItem="{Binding SelectedAprovizionare}" AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding IdAprovizionare}" Width="60"/>
                            <DataGridTextColumn Header="Лекарство" Binding="{Binding MedicamentDenumire}" Width="220"/>
                            <DataGridTextColumn Header="Поставщик" Binding="{Binding FurnizorDenumire}" Width="200"/>
                            <DataGridTextColumn Header="Дата" Binding="{Binding DataAprovizionare, StringFormat=dd.MM.yyyy}" Width="110"/>
                            <DataGridTextColumn Header="Количество" Binding="{Binding Cantitate}" Width="100"/>
                            <DataGridTextColumn Header="Цена" Binding="{Binding PretAchizitie, StringFormat={}{0:F2}}" Width="100"/>
                            <DataGridTextColumn Header="Стоимость" Binding="{Binding CostTotal, StringFormat={}{0:F2}}" Width="110"/>
                            <DataGridTextColumn Header="Истекает" Binding="{Binding DataExpirare, StringFormat=dd.MM.yyyy}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Отчет">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Нажмите кнопку в заголовке, чтобы открыть и экспортировать краткий отчет." TextWrapping="Wrap" FontSize="14" Margin="0,0,0,8"/>
                    <TextBlock Grid.Row="1" Text="Отчет формируется в отдельном окне и может быть сохранен в TXT." TextWrapping="Wrap"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
